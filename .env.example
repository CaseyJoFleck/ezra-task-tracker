# Copy to .env and adjust. Used by docker compose (optional).

# Host ports (maps to containers in docker-compose.yml)
API_PORT=5000
WEB_PORT=3000

# ASP.NET Core (passed to api service when implemented)
ASPNETCORE_ENVIRONMENT=Development

# Docker Compose sets SQLite path for the API container. For local `dotnet run`, see appsettings.json.
# ConnectionStrings__Default=Data Source=/data/careops.db
# Frontend__PublicOrigin=http://localhost:3000
# CORS__AllowedOrigins__0=http://localhost:3000
